{
  "name": "balisticnote-pro",
  "version": "1.0.0",
  "description": "BalisticNote Pro — ballistic calculator and reload log",
  "private": true,
  "scripts": {
    "sync": "cap sync android",
    "open": "cap open android",
    "icons": "capacitor-assets generate --android --iconBackgroundColor '#0a0e14' --iconBackgroundColorDark '#0a0e14'",
    "build:debug": "cap sync android && cd android && ./gradlew assembleDebug",
    "build:release": "cap sync android && cd android && ./gradlew assembleRelease",
    "install:debug": "cd android && ./gradlew installDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.0.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor-community/bluetooth-le": "^8.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/assets": "^3.0.5"
  }
}
